<odoo>
    <record id="view_eventmind_event_list" model="ir.ui.view">
        <field name="name">eventmind.event.list</field>
        <field name="model">eventmind.event</field>
        <field name="arch" type="xml">
            <list string="События">
                <field name="name"/>
                <field name="date_start"/>
                <field name="location"/>
                <field name="category"/>
                <field name="is_recommended"/>
            </list>
        </field>
    </record>

    <record id="view_eventmind_event_form" model="ir.ui.view">
        <field name="name">eventmind.event.form</field>
        <field name="model">eventmind.event</field>
        <field name="arch" type="xml">
            <form string="Событие">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date_start"/>
                        <field name="location"/>
                        <field name="category"/>
                        <field name="is_recommended"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_eventmind_event_search" model="ir.ui.view">
        <field name="name">eventmind.event.search</field>
        <field name="model">eventmind.event</field>
        <field name="arch" type="xml">
            <search string="Поиск событий">
                <field name="name"/>
                <field name="location"/>
                <field name="category"/>
                <filter name="recommended" string="Рекомендованные" domain="[('is_recommended', '=', True)]"/>
                <group expand="0" string="Группировка">
                    <filter name="group_by_category" string="По категории" context="{'group_by': 'category'}"/>
                    <filter name="group_by_location" string="По месту" context="{'group_by': 'location'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_eventmind_event" model="ir.actions.act_window">
        <field name="name">События</field>
        <field name="res_model">eventmind.event</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_eventmind_event_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Создай первое событие для EventMind
            </p>
        </field>
    </record>
</odoo>

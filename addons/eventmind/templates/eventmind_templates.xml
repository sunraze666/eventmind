<odoo>
    <template id="eventmind_events_page" name="EventMind Events Page">
        <t t-call="website.layout">
            <div class="container my-5">
                <h1 class="mb-4">События EventMind</h1>

                <section class="em-calendar-section mb-5" data-em-calendar="">
                    <div class="em-calendar-header">
                        <h2 class="em-calendar-title mb-0">Календарь событий</h2>
                        <div class="em-calendar-nav">
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="prev">←</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="today">Сегодня</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="next">→</button>
                        </div>
                    </div>

                    <div class="em-calendar-toolbar">
                        <div class="em-view-switch" role="tablist" aria-label="Вид календаря">
                            <button type="button" class="btn btn-sm btn-primary" data-em-view="year">Год</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="month">Месяц</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="week">Неделя</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="day">День</button>
                        </div>
                        <div class="em-density-switch" role="tablist" aria-label="Плотность событий">
                            <button type="button" class="btn btn-sm btn-primary" data-em-density="tone">Оттенки</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-density="count">Цифры</button>
                        </div>
                        <div class="em-calendar-current" data-em-current-label=""></div>
                    </div>

                    <div class="em-calendar-body" data-em-calendar-body=""></div>

                    <script id="em-calendar-events" type="application/json"><t t-raw="calendar_events_json"/></script>
                    <p class="em-calendar-note mb-0">Режим "Оттенки" показывает нагрузку по дням цветом, "Цифры" - точным количеством.</p>
                </section>

                <div class="row">
                    <t t-foreach="events" t-as="event" t-key="event.id">
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm p-3">
                                <h4><t t-esc="event.name"/></h4>

                                <p>
                                    <strong>Дата:</strong>
                                    <t t-esc="event.date_start"/>
                                </p>

                                <p>
                                    <strong>Место:</strong>
                                    <t t-esc="event.location"/>
                                </p>

                                <p t-if="event.price">
                                    <strong>Цена:</strong>
                                    <t t-esc="event.price"/>
                                </p>

                                <p t-if="event.age_limit">
                                    <strong>Возраст:</strong>
                                    <t t-esc="event.age_limit"/>
                                </p>

                                <p t-if="event.description">
                                    <t t-esc="event.description[:180]"/>
                                    <t t-if="len(event.description) > 180">...</t>
                                </p>

                                <a t-if="event.source_url"
                                   t-att-href="event.source_url"
                                   target="_blank"
                                   class="btn btn-primary">
                                    Открыть источник
                                </a>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>

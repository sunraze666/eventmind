<odoo>
    <template id="eventmind_site_header" name="EventMind Site Header">
        <div class="em-site-header mb-4">
            <a href="/eventmind/events" class="em-brand-link">EventMind</a>
            <div class="em-site-header-actions">
                <a href="/eventmind/events" class="em-nav-link">Главная</a>
                <t t-if="request.env.user._is_public()">
                    <a href="/eventmind/signup" class="em-nav-link">Регистрация</a>
                    <a href="/eventmind/login" class="em-nav-link em-nav-link-primary">Вход</a>
                </t>
                <t t-else="">
                    <a href="/eventmind/cabinet" class="em-nav-link">Мой кабинет</a>
                    <a href="/web/session/logout?redirect=/eventmind/events" class="em-nav-link">Выйти</a>
                </t>
            </div>
        </div>
    </template>

    <template id="eventmind_events_page" name="EventMind Events Page">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <div class="container my-5">
                <t t-call="eventmind.eventmind_site_header"/>
                <h1 class="mb-4">События EventMind</h1>

                <section class="em-calendar-section mb-5" data-em-calendar="">
                    <div class="em-calendar-header">
                        <h2 class="em-calendar-title mb-0">Календарь событий</h2>
                        <div class="em-calendar-nav">
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="prev">&lt;</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="today">Сегодня</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="next">&gt;</button>
                        </div>
                    </div>

                    <div class="em-calendar-toolbar">
                        <div class="em-view-switch" role="tablist" aria-label="Режим календаря">
                            <button type="button" class="btn btn-sm btn-primary" data-em-view="year">Год</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="month">Месяц</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="week">Неделя</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="day">День</button>
                        </div>
                        <div class="em-density-switch" role="tablist" aria-label="Плотность событий">
                            <button type="button" class="btn btn-sm btn-primary" data-em-density="tone">Оттенок</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-density="count">Число</button>
                        </div>
                        <div class="em-calendar-current" data-em-current-label=""></div>
                    </div>

                    <div class="em-calendar-body" data-em-calendar-body=""></div>

                    <script id="em-calendar-events" type="application/json"><t t-raw="calendar_events_json"/></script>
                    <p class="em-calendar-note mb-0">Режим «Оттенок» подсвечивает загруженность дня, режим «Число» показывает количество событий.</p>
                </section>

                <section t-if="recommendation_items" class="mb-5">
                    <h2 class="mb-3">Recommended for you</h2>
                    <div class="row">
                        <t t-foreach="recommendation_items" t-as="item" t-key="item.event.id">
                            <t t-set="event" t-value="item.event"/>
                            <div class="col-md-4 mb-4">
                                <div class="card h-100 shadow-sm p-3 em-recommendation-card">
                                    <div class="d-flex justify-content-between gap-2 mb-2">
                                        <h4 class="mb-0"><t t-esc="event.name"/></h4>
                                        <span class="badge bg-success">AI</span>
                                    </div>
                                    <p class="text-muted mb-2">Score: <t t-esc="item.score"/></p>
                                    <p><strong>Date:</strong> <t t-esc="event.date_start"/></p>
                                    <p><strong>Place:</strong> <t t-esc="event.location or '-'"/></p>
                                    <p class="text-muted"><t t-esc="item.reason"/></p>
                                    <div class="d-flex flex-wrap gap-2 mt-auto">
                                        <a t-if="event.source_url" t-att-href="event.source_url" target="_blank" class="btn btn-primary">Details</a>
                                        <form t-att-action="'/eventmind/cabinet/calendar/add/%s' % event.id" method="post" class="d-inline">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="redirect" value="/eventmind/events"/>
                                            <button type="submit" class="btn btn-outline-success">Add to calendar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </section>

                <div class="row">
                    <t t-foreach="events" t-as="event" t-key="event.id">
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm p-3">
                                <div class="d-flex justify-content-between gap-2">
                                    <h4><t t-esc="event.name"/></h4>
                                    <span t-if="event.id in recommended_event_ids" class="badge bg-success align-self-start">AI</span>
                                </div>

                                <p>
                                    <strong>Дата:</strong>
                                    <t t-esc="event.date_start"/>
                                </p>

                                <p>
                                    <strong>Место:</strong>
                                    <t t-esc="event.location"/>
                                </p>

                                <p t-if="event.price">
                                    <strong>Цена:</strong>
                                    <t t-esc="event.price"/>
                                </p>

                                <p t-if="event.age_limit">
                                    <strong>Возраст:</strong>
                                    <t t-esc="event.age_limit"/>
                                </p>

                                <p t-if="event.description">
                                    <t t-esc="event.description[:180]"/>
                                    <t t-if="len(event.description) > 180">...</t>
                                </p>

                                <div class="d-flex flex-wrap gap-2 mt-auto">
                                    <a t-if="event.source_url"
                                       t-att-href="event.source_url"
                                       target="_blank"
                                       class="btn btn-primary">
                                        Подробнее
                                    </a>

                                    <t t-if="request.env.user._is_public()">
                                        <a href="/eventmind/login" class="btn btn-outline-primary">Войдите, чтобы добавить</a>
                                    </t>
                                    <t t-else="">
                                        <t t-if="event.id in user_event_ids">
                                            <form t-att-action="'/eventmind/cabinet/calendar/remove/%s' % event.id" method="post" class="d-inline">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="redirect" value="/eventmind/events"/>
                                                <button type="submit" class="btn btn-outline-danger">Удалить из моего календаря</button>
                                            </form>
                                        </t>
                                        <t t-else="">
                                            <form t-att-action="'/eventmind/cabinet/calendar/add/%s' % event.id" method="post" class="d-inline">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="redirect" value="/eventmind/events"/>
                                                <button type="submit" class="btn btn-outline-success">Добавить в мой календарь</button>
                                            </form>
                                        </t>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <template id="eventmind_login_page" name="EventMind Login Page">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <div class="container my-5" style="max-width: 560px;">
                <t t-call="eventmind.eventmind_site_header"/>
                <h1 class="mb-3">Вход</h1>
                <p class="text-muted">Войдите в аккаунт EventMind, чтобы открыть личный кабинет и календарь.</p>

                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <form action="/eventmind/login" method="post" class="card p-4 shadow-sm">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="mb-3">
                        <label class="form-label" for="em_login_email">Email</label>
                        <input id="em_login_email" type="email" name="login" class="form-control" required="required" t-att-value="login or ''"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="em_login_password">Пароль</label>
                        <input id="em_login_password" type="password" name="password" class="form-control" required="required"/>
                    </div>

                    <button type="submit" class="btn btn-primary">Войти</button>
                </form>

                <div class="mt-3">
                    <a href="/eventmind/signup">Нет аккаунта? Зарегистрируйтесь</a>
                </div>
            </div>
        </t>
    </template>

    <template id="eventmind_signup_page" name="EventMind Signup Page">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <div class="container my-5" style="max-width: 700px;">
                <t t-call="eventmind.eventmind_site_header"/>
                <h1 class="mb-3">Регистрация</h1>
                <p class="text-muted">Заполните профиль один раз, эти данные будут использоваться для персональных рекомендаций.</p>

                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <form action="/eventmind/signup" method="post" class="card p-4 shadow-sm">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="mb-3">
                        <label class="form-label" for="em_signup_name">ФИО</label>
                        <input id="em_signup_name" type="text" name="full_name" class="form-control" required="required" t-att-value="(values or {}).get('full_name', '')"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="em_signup_email">Email</label>
                        <input id="em_signup_email" type="email" name="login" class="form-control" required="required" t-att-value="(values or {}).get('login', '')"/>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="em_signup_password">Пароль</label>
                            <input id="em_signup_password" type="password" name="password" class="form-control" required="required"/>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="em_signup_password_confirm">Повторите пароль</label>
                            <input id="em_signup_password_confirm" type="password" name="password_confirm" class="form-control" required="required"/>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label" for="em_signup_age">Возраст</label>
                            <input id="em_signup_age" type="number" min="0" max="120" name="age" class="form-control" t-att-value="(values or {}).get('age', '')"/>
                        </div>
                        <div class="col-md-8 mb-3">
                            <label class="form-label" for="em_signup_gender">Пол</label>
                            <select id="em_signup_gender" name="gender" class="form-select">
                                <option value="">Не указан</option>
                                <option value="male" t-att-selected="'selected' if (values or {}).get('gender') == 'male' else None">Мужской</option>
                                <option value="female" t-att-selected="'selected' if (values or {}).get('gender') == 'female' else None">Женский</option>
                                <option value="other" t-att-selected="'selected' if (values or {}).get('gender') == 'other' else None">Другой</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Интересы</label>
                        <div class="em-interest-tags">
                            <t t-foreach="interest_tags" t-as="tag" t-key="tag">
                                <label class="em-tag-option">
                                    <input type="checkbox" name="interests" t-att-value="tag" t-att-checked="'checked' if tag in ((values or {}).get('interests', [])) else None"/>
                                    <span><t t-esc="tag"/></span>
                                </label>
                            </t>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Создать аккаунт</button>
                </form>

                <div class="mt-3">
                    <a href="/eventmind/login">Уже есть аккаунт? Войти</a>
                </div>
            </div>
        </t>
    </template>

    <template id="eventmind_cabinet_page" name="EventMind Cabinet Page">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <div class="container my-5">
                <t t-call="eventmind.eventmind_site_header"/>
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
                    <div>
                        <h1 class="mb-1">Личный кабинет</h1>
                        <p class="text-muted mb-0">Добро пожаловать, <t t-esc="profile.name"/>.</p>
                    </div>
                </div>

                <div class="card p-3 mb-4">
                    <h4 class="mb-3">Профиль</h4>
                    <div><strong>ФИО:</strong> <t t-esc="profile.name or '-'"/></div>
                    <div><strong>Возраст:</strong> <t t-esc="profile.em_age or '-'"/></div>
                    <div><strong>Пол:</strong> <t t-esc="gender_label"/></div>
                    <div><strong>Интересы:</strong> <t t-esc="profile.em_interests or '-'"/></div>
                </div>

                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>
                <div t-if="success" class="alert alert-success" role="alert">
                    <t t-esc="success"/>
                </div>

                <details class="em-profile-editor mb-4">
                    <summary class="btn btn-outline-primary">Редактировать профиль</summary>
                    <div class="card p-3 mt-3">
                        <form action="/eventmind/cabinet" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="action" value="update_profile"/>

                            <div class="mb-3">
                                <label class="form-label" for="em_cabinet_name">ФИО</label>
                                <input id="em_cabinet_name" type="text" name="full_name" class="form-control" required="required" t-att-value="(profile_form_values or {}).get('full_name', '')"/>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label" for="em_cabinet_email">Email</label>
                                    <input id="em_cabinet_email" type="email" name="email" class="form-control" required="required" t-att-value="(profile_form_values or {}).get('email', '')"/>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label" for="em_cabinet_age">Возраст</label>
                                    <input id="em_cabinet_age" type="number" min="0" max="120" name="age" class="form-control" t-att-value="(profile_form_values or {}).get('age', '')"/>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label" for="em_cabinet_gender">Пол</label>
                                    <select id="em_cabinet_gender" name="gender" class="form-select">
                                        <option value="" t-att-selected="'selected' if (profile_form_values or {}).get('gender') == '' else None">Не указан</option>
                                        <option value="male" t-att-selected="'selected' if (profile_form_values or {}).get('gender') == 'male' else None">Мужской</option>
                                        <option value="female" t-att-selected="'selected' if (profile_form_values or {}).get('gender') == 'female' else None">Женский</option>
                                        <option value="other" t-att-selected="'selected' if (profile_form_values or {}).get('gender') == 'other' else None">Другой</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="em_cabinet_current_password_for_email">Текущий пароль (только если меняете email)</label>
                                <input id="em_cabinet_current_password_for_email" type="password" name="current_password_for_email" class="form-control"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Интересы</label>
                                <div class="em-interest-tags">
                                    <t t-foreach="interest_tags" t-as="tag" t-key="tag">
                                        <label class="em-tag-option">
                                            <input type="checkbox" name="interests" t-att-value="tag" t-att-checked="'checked' if tag in ((profile_form_values or {}).get('interests', [])) else None"/>
                                            <span><t t-esc="tag"/></span>
                                        </label>
                                    </t>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary">Сохранить профиль</button>
                        </form>

                        <hr class="my-4"/>

                        <h4 class="mb-3">Сменить пароль</h4>
                        <form action="/eventmind/cabinet" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="action" value="change_password"/>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label" for="em_current_password">Текущий пароль</label>
                                    <input id="em_current_password" type="password" name="current_password" class="form-control" required="required"/>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label" for="em_new_password">Новый пароль</label>
                                    <input id="em_new_password" type="password" name="new_password" class="form-control" required="required"/>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label" for="em_confirm_password">Подтвердите пароль</label>
                                    <input id="em_confirm_password" type="password" name="confirm_password" class="form-control" required="required"/>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-outline-primary">Изменить пароль</button>
                        </form>
                    </div>
                </details>

                <section class="em-calendar-section mb-4" data-em-calendar="">
                    <div class="em-calendar-header">
                        <h2 class="em-calendar-title mb-0">Мой календарь</h2>
                        <div class="em-calendar-nav">
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="prev">&lt;</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="today">Сегодня</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-em-nav="next">&gt;</button>
                        </div>
                    </div>

                    <div class="em-calendar-toolbar">
                        <div class="em-view-switch" role="tablist" aria-label="Режим календаря">
                            <button type="button" class="btn btn-sm btn-primary" data-em-view="year">Год</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="month">Месяц</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="week">Неделя</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-view="day">День</button>
                        </div>
                        <div class="em-density-switch" role="tablist" aria-label="Плотность событий">
                            <button type="button" class="btn btn-sm btn-primary" data-em-density="tone">Оттенок</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-em-density="count">Число</button>
                        </div>
                        <div class="em-calendar-current" data-em-current-label=""></div>
                    </div>

                    <div class="em-calendar-body" data-em-calendar-body=""></div>

                    <script id="em-calendar-events" type="application/json"><t t-raw="calendar_events_json"/></script>
                </section>

                <section t-if="recommendation_items" class="mb-4">
                    <h3 class="mb-3">Recommended for you</h3>
                    <div class="row">
                        <t t-foreach="recommendation_items" t-as="item" t-key="item.event.id">
                            <t t-set="event" t-value="item.event"/>
                            <div class="col-md-4 mb-4">
                                <div class="card h-100 shadow-sm p-3 em-recommendation-card">
                                    <div class="d-flex justify-content-between gap-2 mb-2">
                                        <h4 class="mb-0"><t t-esc="event.name"/></h4>
                                        <span class="badge bg-success">AI</span>
                                    </div>
                                    <p class="text-muted mb-2">Score: <t t-esc="item.score"/></p>
                                    <p><strong>Date:</strong> <t t-esc="event.date_start"/></p>
                                    <p><strong>Place:</strong> <t t-esc="event.location or '-'"/></p>
                                    <p class="text-muted"><t t-esc="item.reason"/></p>
                                    <div class="d-flex flex-wrap gap-2 mt-auto">
                                        <a t-if="event.source_url" t-att-href="event.source_url" target="_blank" class="btn btn-primary">Details</a>
                                        <form t-att-action="'/eventmind/cabinet/calendar/add/%s' % event.id" method="post" class="d-inline">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-outline-success">Add to calendar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </section>

                <h3 class="mb-3">События в моем календаре</h3>
                <div class="row">
                    <t t-if="events">
                        <t t-foreach="events" t-as="event" t-key="event.id">
                            <div class="col-md-4 mb-4">
                                <div class="card h-100 shadow-sm p-3">
                                    <h4><t t-esc="event.name"/></h4>
                                    <p><strong>Дата:</strong> <t t-esc="event.date_start"/></p>
                                    <p><strong>Место:</strong> <t t-esc="event.location or '-'"/></p>
                                    <div class="d-flex gap-2 mt-auto">
                                        <a t-if="event.source_url" t-att-href="event.source_url" target="_blank" class="btn btn-primary">Подробнее</a>
                                        <form t-att-action="'/eventmind/cabinet/calendar/remove/%s' % event.id" method="post" class="d-inline">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-outline-danger">Удалить</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="col-12">
                            <div class="alert alert-info">Ваш календарь пока пуст. Откройте все события и добавьте интересные.</div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
